# ── Storage ──────────────────────────────────────────────────────────
# Your own Supabase project (self-hosted memory — your infra, your data).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Embeddings ───────────────────────────────────────────────────────
# Default provider is Voyage (voyage-3-large, 1024 dims — strong
# multilingual quality). The vector dimension in db/schema.sql must
# match your embedding model's output dimension.
VOYAGE_API_KEY=

# ── Classification executor ──────────────────────────────────────────
# Pick ONE backend for the session classifier:
#
# (a) Anthropic API (first-class: mines extended-thinking blocks when present)
ANTHROPIC_API_KEY=

# (b) Any OpenAI-compatible endpoint (OpenAI, Gemini, DeepSeek, Ollama,
#     LM Studio, vLLM, ...). Set both to enable:
# CLASSIFY_BASE_URL=
# CLASSIFY_API_KEY=
# CLASSIFY_MODEL=
